          "reduceOptions": { "calcs": ["lastNotNull"] },
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "fixed", "fixedColor": "blue" },
            "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
          }
        },
        "targets": [{
          "datasource": { "type": "influxdb", "uid": "cfgvijnkiwk5ca" },
          "query": "from(bucket: \"Aurora\")\n  |> range(start: -2m)\n  |> filter(fn: (r) => r._measurement == \"aurora_mes\" and r._field == \"batch_id\")\n  |> last()",
          "refId": "A"
        }]
