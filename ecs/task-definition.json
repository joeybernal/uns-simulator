{
  "family": "uns-simulator",
  "taskRoleArn": "arn:aws:iam::881490131520:role/pipeline-monitor-ecs-task-role",
  "executionRoleArn": "arn:aws:iam::881490131520:role/pipeline-monitor-ecs-execution-role",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "256",
  "memory": "512",
  "containerDefinitions": [
    {
      "name": "uns-simulator",
      "image": "881490131520.dkr.ecr.eu-central-1.amazonaws.com/uns-simulator:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp",
          "name": "http"
        }
      ],
      "environment": [
        {
          "name": "MQTT_HOST",
          "value": "mqtt.iotdemozone.com"
        },
        {
          "name": "MQTT_PORT",
          "value": "1883"
        },
        {
          "name": "MQTT_USER",
          "value": "admin"
        },
        {
          "name": "SERVER_PORT",
          "value": "8080"
        }
      ],
      "secrets": [
        {
          "name": "MQTT_PASS",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:881490131520:secret:pipeline-monitor/mqtt-password-Vt925U"
        },
        {
          "name": "SIM_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:eu-central-1:881490131520:secret:uns-simulator/sim-api-key-69XUkC:api_key::"
        }
      ],
      "stopTimeout": 30,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/uns-simulator",
          "awslogs-region": "eu-central-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "python3 -c \"import urllib.request; urllib.request.urlopen('http://localhost:8080/health')\" || exit 1"
        ],
        "interval": 30,
        "timeout": 10,
        "retries": 3,
        "startPeriod": 45
      }
    }
  ]
}
